# =============================================================================
# .env.example — Copy to .env and fill in your real values
# NEVER commit the real .env to git.
# =============================================================================

# ── Bright Data Scraper API ───────────────────────────────────────────────────
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here

# ── Google Sheets / GCP ──────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Apify API ─────────────────────────────────────────────────────────────────
# Get from: https://console.apify.com → Settings → API Token
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# ── Firecrawl API ─────────────────────────────────────────────────────────────
# Get from: https://www.firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx


# ── Twitter / X API (optional) ───────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── YouTube Data API (optional) ──────────────────────────────────────────────
YOUTUBE_API_KEY=

# ── Bright Data Proxy (if using manual scraping mode) ────────────────────────
BRIGHT_DATA_PROXY_HOST=
BRIGHT_DATA_PROXY_PORT=33335
BRIGHT_DATA_USERNAME=
BRIGHT_DATA_PASSWORD=
